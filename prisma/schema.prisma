generator client {
  provider = "prisma-client-js"
} 

datasource db {
  provider = "postgresql"
}

model Product {
  id                String    @id @default(uuid())
  codigoProduto     String    @unique
  descricaoProduto  String
  status            Boolean   @default(true)
  fotoProduto       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}